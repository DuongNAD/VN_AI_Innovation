# Database connection URL
DATABASE_URL=postgresql://user:pass@localhost:5432/psp

# AI Provider (mock | openai)
AI_PROVIDER=mock

# OpenAI API Key (required only when AI_PROVIDER=openai)
OPENAI_API_KEY=

# OpenAI API Base URL (https required in production; http only for localhost in dev)
OPENAI_BASE_URL=https://api.openai.com/v1

# Model configurations
LLM_MODEL=gpt-4o-mini
STT_MODEL=whisper-1
TTS_MODEL=tts-1

# Shared Admin Token for administrator actions (/admin, approve)
# DEMO ONLY — production refuses to start unless >= 24 chars and not this default
ADMIN_TOKEN=demo-admin-token

# Shared Manager Token for manager portal (/manager, read-only staff APIs)
# DEMO ONLY — production refuses to start unless >= 24 chars and not this default
# Must be different from ADMIN_TOKEN
MANAGER_TOKEN=demo-manager-token

# Rate limit configuration
RATE_LIMIT_PER_MINUTE=10

# Trust proxy header configuration
# Set to 1 ONLY behind a trusted edge proxy that appends x-forwarded-for (e.g. Render)
TRUST_PROXY=0

# Session TTL configuration
SESSION_TTL_HOURS=24

# Optional real OAuth (when unset, Google/Facebook use demo callback)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=

# VNeID: set VNID_DEMO=0 to disable demo confirm endpoint
# VNID_DEMO=1
# Local PostgreSQL container credentials (docker-compose.yml reads these).
# Placeholder values for the local demo container only — change for anything
# shared, and keep DATABASE_URL below in sync.
POSTGRES_USER=user
POSTGRES_PASSWORD=postgres
POSTGRES_DB=psp

# Database connection URL
DATABASE_URL=postgresql://user:postgres@localhost:5432/psp

# AI Provider (mock | openai)
AI_PROVIDER=mock

# Safety override for intentionally disposable production-like demo databases.
# Leave unset/0 in real production: prisma/seed.ts refuses to reset workflow state.
ALLOW_DEMO_SEED=0

# OpenAI API Key (required only when AI_PROVIDER=openai)
OPENAI_API_KEY=

# OpenAI API Base URL (https required in production; http only for localhost in dev)
OPENAI_BASE_URL=https://api.openai.com/v1

# Model configurations
LLM_MODEL=gpt-4o-mini
STT_MODEL=whisper-1
TTS_MODEL=tts-1

# Shared Admin Token for administrator actions
# DEMO ONLY — works as-is for local runs; production refuses to start unless
# the value is >= 24 printable chars, has >= 8 distinct chars, and is not this
# default (generate one with: openssl rand -hex 32)
ADMIN_TOKEN=demo-admin-token

# Rate limit configuration
RATE_LIMIT_PER_MINUTE=10

# Trust proxy header configuration
# Set to 1 ONLY behind a trusted edge proxy that appends x-forwarded-for (e.g. Render)
TRUST_PROXY=0

# Session TTL configuration
SESSION_TTL_HOURS=24

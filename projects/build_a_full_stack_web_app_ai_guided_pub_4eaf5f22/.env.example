# Local PostgreSQL container credentials (docker-compose.yml reads these).
# Placeholder values for the local demo container only — change for anything
# shared, and keep DATABASE_URL below in sync.
POSTGRES_USER=user
POSTGRES_PASSWORD=postgres
POSTGRES_DB=psp

# Database connection URL
DATABASE_URL=postgresql://user:postgres@localhost:5432/psp

# AI Provider (mock | openai)
AI_PROVIDER=mock

# Safety override for intentionally disposable production-like demo databases.
# Leave unset/0 in real production: prisma/seed.ts refuses to reset workflow state.
ALLOW_DEMO_SEED=0

# Shared OpenAI-compatible API Key (fallback when per-service keys are unset)
OPENAI_API_KEY=

# Optional per-service API keys — override OPENAI_API_KEY per service. Useful
# for providers that scope keys to a single model (e.g. FPT AI Marketplace).
LLM_API_KEY=
STT_API_KEY=
TTS_API_KEY=

# OpenAI-compatible API Base URL (https required in production; http only for
# localhost in dev). Production allows only api.openai.com or mkp-api.fptcloud.com.
# FPT AI Marketplace: https://mkp-api.fptcloud.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Model configurations
# FPT AI Marketplace ids: DeepSeek-V4-Flash / FPT.AI-whisper-large-v3-turbo / FPT.AI-VITs
LLM_MODEL=gpt-4o-mini
STT_MODEL=whisper-1
TTS_MODEL=tts-1
# Vision model used to check the citizen's signed declaration (tờ khai đã ký)
# before it reaches the officer. Must be multimodal (image input). Defaults to
# gpt-4o-mini when unset. FPT AI Marketplace id: gemma-4-31B-it.
VISION_MODEL=gpt-4o-mini
# Key for the vision model. Marketplaces issue one key per model, so this is
# separate from LLM_API_KEY; falls back to OPENAI_API_KEY when unset. Optional —
# without a working key the check degrades to "cán bộ xem trực tiếp" (SKIPPED).
VISION_API_KEY=

# Set to 1 for reasoning LLMs behind vLLM-compatible endpoints (e.g.
# DeepSeek-V4-Flash) so answers land in message.content. Keep 0/unset for OpenAI.
LLM_DISABLE_THINKING=0

# Upstream TTS voice ids mapped to the app's vi-female / vi-male voices.
# OpenAI: nova / onyx (defaults). FPT.AI-VITs: banmai / leminh (+ thuminh,
# kimngan, hatieumai, ngoclam, giahuy, minhquan, huyphong).
TTS_VOICE_FEMALE=nova
TTS_VOICE_MALE=onyx

# Shared Admin Token for administrator actions
# DEMO ONLY — works as-is for local runs; production refuses to start unless
# the value is >= 24 printable chars, has >= 8 distinct chars, and is not this
# default (generate one with: openssl rand -hex 32)
ADMIN_TOKEN=demo-admin-token

# OPTIONAL legacy shared token for the X-Manager-Token header (automation only).
# Managers sign in with seeded accounts — leave unset to disable this path.
# If set: must differ from ADMIN_TOKEN; production enforces >= 24 strong chars.
# MANAGER_TOKEN=

# Rate limit configuration
RATE_LIMIT_PER_MINUTE=10

# Trust proxy header configuration
# Set to 1 ONLY behind a trusted edge proxy that appends x-forwarded-for (e.g. Render)
TRUST_PROXY=0

# Session TTL configuration
SESSION_TTL_HOURS=24

# Secret used to encrypt temporary identity-card images at rest.
# Use a unique random value of at least 32 characters in every environment.
IDENTITY_DOCUMENT_KEY=

# Optional real OAuth (when unset, Google/Facebook use demo callback)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=

# VNeID: set VNID_DEMO=0 to disable demo confirm endpoint
# VNID_DEMO=1

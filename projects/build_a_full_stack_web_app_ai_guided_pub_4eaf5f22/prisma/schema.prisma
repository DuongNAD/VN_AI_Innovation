datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Procedure {
  id                  String                @id @default(cuid())
  code                String                @unique
  name                String
  sector              String
  agency              String
  // Target audience of the procedure: CITIZEN (công dân) or BUSINESS (doanh nghiệp)
  audience            String                @default("CITIZEN")
  sourceUrl           String
  lastCheckedAt       DateTime
  versions            ProcedureVersion[]
  clarifyingQuestions ClarifyingQuestion[]
  documentRequirements DocumentRequirement[]
  forms               Form[]
}

model ProcedureVersion {
  id             String    @id @default(cuid())
  procedureId    String
  procedure      Procedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  version        String
  status         String
  effectiveFrom  DateTime?
  effectiveTo    DateTime?
  stepsJson      Json
  durationText   String
  feesText       String
  legalBasisText String?

  @@unique([procedureId, version])
}

model ClarifyingQuestion {
  id            String    @id @default(cuid())
  procedureId   String
  procedure     Procedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  code          String
  orderNumber   Int
  fieldType     String
  optionsJson   Json?
  conditionJson Json?
  questionText  String

  @@unique([procedureId, code])
}

model DocumentRequirement {
  id             String    @id @default(cuid())
  procedureId    String
  procedure      Procedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  code           String
  name           String
  originals      Int
  copies         Int
  orderNumber    Int
  conditionJson  Json?
  reasonText     String?
  submissionType String    @default("SUBMIT")

  @@index([procedureId])
}

model Form {
  id          String        @id @default(cuid())
  code        String        @unique
  procedureId String
  procedure   Procedure     @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  name        String
  revision    Int           @default(0)
  versions    FormVersion[]
}

model FormVersion {
  id             String           @id @default(cuid())
  formId         String
  form           Form             @relation(fields: [formId], references: [id], onDelete: Cascade)
  version        String
  status         String
  effectiveFrom  DateTime?
  effectiveTo    DateTime?
  schemaJson     Json
  rules          ValidationRule[]
  applications   Application[]
  changeRequests ChangeRequest[]

  @@unique([formId, version])
}

model ValidationRule {
  id            String      @id @default(cuid())
  formVersionId String
  formVersion   FormVersion @relation(fields: [formVersionId], references: [id], onDelete: Cascade)
  type          String
  fieldId       String?
  paramsJson    Json
  message       String
  suggestion    String
  severity      String      @default("error")
  orderNumber   Int

  @@index([formVersionId])
}

model Session {
  id              String        @id @default(cuid())
  accessTokenHash String        @unique
  procedureCode   String
  intent          String?
  answersJson     Json
  currentStep     Int           @default(0)
  expiresAt       DateTime
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  applications    Application[]

  @@index([expiresAt])
}

model Application {
  id            String      @id @default(cuid())
  sessionId     String
  session       Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  formVersionId String
  formVersion   FormVersion @relation(fields: [formVersionId], references: [id], onDelete: Cascade)
  // DRAFT -> SUBMITTED -> APPROVED | RETURNED (RETURNED can be edited and re-submitted)
  status        String      @default("DRAFT")
  dataJson      Json
  revision      Int         @default(0)
  submittedAt   DateTime?
  reviewedAt    DateTime?
  reviewedBy    String?
  reviewNote    String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([sessionId])
  @@index([formVersionId])
  @@index([status])
}

model ChangeRequest {
  id               String      @id @default(cuid())
  oldVersionId     String
  oldVersion       FormVersion @relation(fields: [oldVersionId], references: [id], onDelete: Cascade)
  status           String      @default("PENDING")
  sourceUrl        String
  diffJson         Json
  proposedDataJson Json
  reviewedBy       String?
  reviewedAt       DateTime?
  createdAt        DateTime    @default(now())

  @@index([oldVersionId])
  @@index([status])
}

model AiUsageLog {
  id               String   @id @default(cuid())
  serviceType      String
  model            String
  promptTokens     Int?
  completionTokens Int?
  audioSeconds     Float?
  latencyMs        Int
  cacheHit         Boolean  @default(false)
  degraded         Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@index([createdAt])
}

model IdempotencyRecord {
  principalId  String
  key          String
  httpStatus   Int
  responseJson Json
  createdAt    DateTime @default(now())

  @@id([principalId, key])
  @@index([createdAt])
}

// Durable cache for synthesized TTS audio. TTS is billed per character and the
// same guidance/question text is read aloud repeatedly, so persisting audio here
// lets every serverless instance (and every restart) reuse it instead of re-paying
// the upstream. `key` is the app-level cache key (provider:model:hash of
// text+voice+speed+language); audio bytes are stored inline since clips are small.
model TtsCache {
  key            String   @id
  mimeType       String
  model          String
  audio          Bytes
  byteSize       Int
  createdAt      DateTime @default(now())
  lastAccessedAt DateTime @default(now())

  @@index([lastAccessedAt])
}

// Runtime-editable application settings as a small key/value store, so an admin
// can change behaviour (e.g. the TTS delivery mode) without a redeploy. Values
// are short strings; readers fall back to a safe default when a key is absent.
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// Application login identity (citizen / manager / admin).
model User {
  id           String         @id @default(cuid())
  username     String         @unique
  email        String?        @unique
  displayName  String
  phone        String?
  dateOfBirth  DateTime?
  address      String?
  citizenId    String?        @unique
  gender       String?
  placeOfBirth String?
  idIssuedAt   DateTime?
  idExpiresAt  DateTime?
  /// scrypt-encoded password; null for OAuth/VNID-only accounts
  passwordHash String?
  /// user | manager | admin
  role         String
  avatarUrl    String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  loginSessions LoginSession[]
  oauthAccounts OAuthAccount[]
  identityDocument IdentityDocument?
}

/// Encrypted temporary images of the citizen's identity card.
/// Images are user-owned, never public, and are not proof of verified identity.
model IdentityDocument {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status            String   @default("CAPTURED_NOT_VERIFIED")
  frontCiphertext   Bytes
  frontIv           Bytes
  frontAuthTag      Bytes
  frontMimeType     String
  frontByteSize     Int
  backCiphertext    Bytes
  backIv            Bytes
  backAuthTag       Bytes
  backMimeType      String
  backByteSize      Int
  consentAt         DateTime
  expiresAt         DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([expiresAt])
}

/// Linked social providers (Google, Facebook, …).
model OAuthAccount {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// google | facebook
  provider       String
  providerUserId String
  email          String?
  createdAt      DateTime @default(now())

  @@unique([provider, providerUserId])
  @@index([userId])
}

/// Browser login session (httpOnly cookie psp_login).
model LoginSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userAgent String?
  ipHint    String?

  @@index([userId])
}

/// VNeID QR login challenge (poll until CONFIRMED).
model VnidChallenge {
  id        String   @id @default(cuid())
  nonce     String   @unique
  status    String   @default("PENDING")
  /// set when phone confirms / demo confirm
  userId    String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([status])
}
